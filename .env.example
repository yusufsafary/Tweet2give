# ═══════════════════════════════════════════════════════════
# Tweet2Give — Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════

# ─── DEPLOYER ───────────────────────────────────────────────
# Private key of the wallet that will deploy contracts
# Must have ETH on the target network for gas
DEPLOYER_PRIVATE_KEY=0x...

# ─── CONTRACT ADDRESSES (set after deployment) ──────────────
CONTRACT_ADDRESS_BASE=           # Tweet2Give on Base Mainnet
CONTRACT_ADDRESS_BASE_SEPOLIA=   # Tweet2Give on Base Sepolia

# ─── RPC URLS ────────────────────────────────────────────────
# Optional: use Alchemy or Infura for better reliability
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Alchemy (recommended)
ALCHEMY_BASE_MAINNET=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_BASE_SEPOLIA=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# ─── FEE CONFIGURATION ───────────────────────────────────────
# Address to receive platform fees
FEE_RECIPIENT=0x...

# Initial fee in basis points (100 = 1%, 0 = 0% demo mode)
INITIAL_FEE_BPS=0

# ─── VERCEL API ──────────────────────────────────────────────
# Private key of admin wallet for backend-initiated transactions
ADMIN_PRIVATE_KEY=0x...

# Secret key for backend API calls (protect /api/vote POST etc)
ADMIN_API_KEY=change_me_to_something_random_and_long

# Allowed origins for CORS
ALLOWED_ORIGINS=https://tweet2give.fun,https://www.tweet2give.fun,http://localhost:3000

# ─── VERIFICATION ────────────────────────────────────────────
BASESCAN_API_KEY=your_basescan_api_key

# ─── GAS REPORTING (optional) ────────────────────────────────
REPORT_GAS=false
COINMARKETCAP_API_KEY=

# ─── TWITTER/X OAUTH (for login with X) ──────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=https://tweet2give.fun/auth/twitter/callback

# ─── BANKRBOT WEBHOOK ─────────────────────────────────────────
# Secret for verifying @bankrbot webhook payloads
BANKRBOT_WEBHOOK_SECRET=
